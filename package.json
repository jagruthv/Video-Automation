{
  "name": "aura-video-automator",
  "version": "1.0.0",
  "description": "AURA - Autonomous Unified Reels Automator. AI-driven video content factory.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dashboard:api": "node dashboard/api/server.js",
    "dashboard:dev": "cd dashboard && npm run dev",
    "collect-metrics": "node src/modules/analytics-collector.js",
    "competitor-check": "node src/modules/anti-flag-engine.js --mode=competitor-check",
    "strip-old-scripts": "node scripts/strip-old-scripts.js",
    "test": "jest --coverage",
    "validate-env": "node scripts/validate-env.js",
    "setup-oauth": "node scripts/setup-youtube-oauth.js"
  },
  "dependencies": {
    "@rohitaryal/whisk-api": "^4.0.1",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.4.0",
    "edge-tts-universal": "^1.2.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "fake-useragent": "^1.0.0",
    "fastest-levenshtein": "^1.0.16",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0",
    "googleapis": "^140.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "node-gtts": "^2.0.0",
    "rss-parser": "^3.13.0",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "xml-escape": "^1.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
