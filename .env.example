# ============================================================
# AURA - Autonomous Unified Reels Automator
# Environment Variables Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# === DATABASE ===
MONGODB_URI=

# === LLM CASCADE (6 providers, priority order) ===
# Provider 1: Google AI Studio — Gemini 2.5 Flash
# Free: 10 RPM, 250 RPD, 1M token context
GEMINI_API_KEY=

# Provider 2: Groq — Llama 3.3 70B Versatile
# Free: 30 RPM, 1,000 RPD, 6,000 tokens/min
GROQ_API_KEY=

# Provider 3: Cerebras — Llama 3.3 70B
# Free: 30 RPM, 1M tokens/day
CEREBRAS_API_KEY=

# Provider 4: Mistral AI — Mistral Small Latest
# Free: Shared pool, variable limits (~1 RPM). Monitor usage.
MISTRAL_API_KEY=

# Provider 5: GitHub Models — GPT-4o
# Free: 10-15 RPM, 50-150 RPD (depends on GitHub plan)
GITHUB_MODELS_TOKEN=

# Provider 6: OpenRouter — DeepSeek R1 (free)
# Free: 20 RPM, 200 RPD
OPENROUTER_API_KEY=

# === TTS ENGINE (4 tiers) ===
# Tier 1: edge-tts (no key needed, Microsoft Edge Neural API, unlimited)
# Tier 2: Kokoro.js (no key needed, runs locally, Apache 2.0 — dev only, skip on GH Actions)
# Tier 3: OpenAI TTS (OPTIONAL paid — ultra-realistic)
OPENAI_API_KEY=
# Tier 4: gTTS (no key needed, Google — emergency fallback)

# === VISUAL ENGINE ===
# Pexels: 200 req/hour, 20,000 req/month (free, all keys)
PEXELS_API_KEY=
# Pixabay: generous free tier
PIXABAY_API_KEY=
# Pollinations.ai: no key needed (URL-based generation)

# === PLATFORM PUBLISHERS ===
# YouTube Account 1 (Tech Channel)
YT_TECH_MAIN_CLIENT_ID=
YT_TECH_MAIN_CLIENT_SECRET=
YT_TECH_MAIN_REFRESH_TOKEN=

# YouTube Account 2 (History Channel)
YT_HISTORY_CLIENT_ID=
YT_HISTORY_CLIENT_SECRET=
YT_HISTORY_REFRESH_TOKEN=

# Instagram Account 1
IG_TECH_MAIN_ACCESS_TOKEN=
IG_TECH_MAIN_USER_ID=

# Instagram Account 2
IG_HISTORY_ACCESS_TOKEN=
IG_HISTORY_USER_ID=

# X/Twitter (future)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# === AFFILIATE ===
# Bitly: 1,000 links/month free
BITLY_API_KEY=
AFFILIATE_WEBHOOK_SECRET=

# === DASHBOARD ===
DASHBOARD_JWT_SECRET=
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASS=
DASHBOARD_PORT=3001

# === SYSTEM ===
NODE_ENV=production
LOG_LEVEL=info
MAX_DAILY_UPLOADS_PER_CHANNEL=5
UPLOAD_WINDOW_START_HOUR=8
UPLOAD_WINDOW_END_HOUR=23
ANTIFLAG_UNIQUENESS_THRESHOLD=75

# === TEMPORARY VIDEO HOSTING (for Instagram Reels upload) ===
# Option A (Recommended): Cloudflare R2 with presigned URLs
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET_NAME=aura-temp
CF_R2_PUBLIC_DOMAIN=
# Option B: Supabase Storage (1GB free)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=aura-temp
